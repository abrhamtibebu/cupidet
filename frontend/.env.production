# Used by `vite build` / Render Static Site builds (override in the Render dashboard if needed)
# IMPORTANT: must be the *backend* service URL ending in /api — never https://onrender.com or the frontend host.
VITE_API_URL=https://cupidet.onrender.com/api
VITE_MOCK_AUTH=false
VITE_TELEGRAM_BOT_USERNAME=cupidet_bot
VITE_REVERB_APP_KEY=cupidetlocalkey
VITE_REVERB_HOST=cupidet.onrender.com
VITE_REVERB_PORT=443
VITE_REVERB_SCHEME=https
