VITE_API_URL=http://127.0.0.1:8001/api
VITE_MOCK_AUTH=true
VITE_TELEGRAM_BOT_USERNAME=cupidet_bot
VITE_REVERB_APP_KEY=cupidetlocalkey
VITE_REVERB_HOST=127.0.0.1
VITE_REVERB_PORT=8080
VITE_REVERB_SCHEME=http

# Production (Render) example — must be your *backend* service URL, not onrender.com:
# VITE_API_URL=https://cupidet.onrender.com/api
# VITE_REVERB_HOST=cupidet.onrender.com
# VITE_REVERB_PORT=443
# VITE_REVERB_SCHEME=https
